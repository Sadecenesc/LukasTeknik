# =============================================================
# Lukas Teknik — Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env.local olarak kaydedin.
# .env.local hiçbir zaman git'e commit edilmez.
# =============================================================

# -------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard → Settings → API
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase Service Role — sadece sunucu tarafı (admin işlemleri)
# ASLA istemciye açık bir değişkende kullanmayın!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------------
# Site URL
# Geliştirmede: http://localhost:3000
# Prodüksiyonda: https://lukasteknik.com
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------------
# İletişim (gelecekte e-posta bildirimi için)
# -------------------------------------------------------------
# RESEND_API_KEY=re_...
# MAIL_FROM=noreply@lukasteknik.com
# MAIL_TO=info@lukasteknik.com
